<Window x:Class="WpfTcpServer.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:WpfTcpServer"
        Title="1984" Height="720" Width="1100"> 
    <Window.Resources>
        <local:BooleanToBrushConverter x:Key="BooleanToBrushConverter"/>
    </Window.Resources>

    <Grid Margin="10">
        <TabControl>

            <!-- Клиенты -->
            <TabItem Header="Рабочие станции">
                <ListView x:Name="ClientsListView">
                    <ListView.View>
                        <GridView>
                            <GridViewColumn Header="IP" DisplayMemberBinding="{Binding IP}" Width="140"/>
                            <GridViewColumn Header="User Name" DisplayMemberBinding="{Binding UserName}" Width="140"/>
                            <GridViewColumn Header="Domain Name" DisplayMemberBinding="{Binding DomainName}" Width="150"/>
                            <GridViewColumn Header="Host Name" DisplayMemberBinding="{Binding HostName}" Width="150"/>
                            <GridViewColumn Header="Last Active Time" DisplayMemberBinding="{Binding LastActiveTime}" Width="160"/>
                            <GridViewColumn Header="Is Connected" Width="100">
                                <GridViewColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding IsConnected}"
                                                   Foreground="{Binding IsConnected, Converter={StaticResource BooleanToBrushConverter}}"/>
                                    </DataTemplate>
                                </GridViewColumn.CellTemplate>
                            </GridViewColumn>
                            <GridViewColumn Header="Actions" Width="160">
                                <GridViewColumn.CellTemplate>
                                    <DataTemplate>
                                        <Button Content="Запросить скриншот"
                                                Click="RequestScreenshotButton_Click"
                                                Tag="{Binding IP}"/>
                                    </DataTemplate>
                                </GridViewColumn.CellTemplate>
                            </GridViewColumn>
                        </GridView>
                    </ListView.View>
                </ListView>
            </TabItem>

            <!-- Правила приложений -->
            <TabItem Header="Правила приложений">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <StackPanel Orientation="Horizontal" Margin="0 0 0 10">
                        <TextBox x:Name="ApplicationRuleTextBox"
                                 Width="250"
                                 Margin="0 0 10 0"
                                 VerticalContentAlignment="Center"
                                 ToolTip="Например: browser.exe"/>

                        <ComboBox x:Name="ApplicationRuleTypeComboBox"
                                  Width="140"
                                  Margin="0 0 10 0">
                            <ComboBoxItem Content="whitelist"/>
                            <ComboBoxItem Content="blacklist"/>
                        </ComboBox>

                        <Button Content="Добавить"
                                Width="100"
                                Margin="0 0 10 0"
                                Click="AddApplicationRuleButton_Click"/>

                        <Button Content="Удалить выбранное"
                                Width="150"
                                Click="DeleteApplicationRuleButton_Click"/>
                    </StackPanel>

                    <DataGrid x:Name="ApplicationRulesDataGrid"
                          Grid.Row="1"
                          AutoGenerateColumns="False"
                          IsReadOnly="False"
                          SelectionMode="Single"
                          CellEditEnding="ApplicationRulesDataGrid_CellEditEnding">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="ID" Binding="{Binding Id}" Width="60" IsReadOnly="True"/>
                            <DataGridTextColumn Header="Приложение" Binding="{Binding Value}" Width="*" IsReadOnly="True"/>
                            <DataGridTextColumn Header="Тип" Binding="{Binding RuleType}" Width="140" IsReadOnly="True"/>
                            <DataGridCheckBoxColumn Header="Активно" Binding="{Binding IsActive}" Width="100"/>
                            <DataGridTextColumn Header="Создано" Binding="{Binding CreatedAt}" Width="180" IsReadOnly="True"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </TabItem>

            <!-- Правила сайтов -->
            <TabItem Header="Правила сайтов">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <StackPanel Orientation="Horizontal" Margin="0 0 0 10">
                        <TextBox x:Name="WebRuleTextBox"
                                 Width="250"
                                 Margin="0 0 10 0"
                                 VerticalContentAlignment="Center"
                                 ToolTip="Например: youtube.com"/>

                        <ComboBox x:Name="WebRuleTypeComboBox"
                                  Width="140"
                                  Margin="0 0 10 0">
                            <ComboBoxItem Content="whitelist"/>
                            <ComboBoxItem Content="blacklist"/>
                        </ComboBox>

                        <Button Content="Добавить"
                                Width="100"
                                Margin="0 0 10 0"
                                Click="AddWebRuleButton_Click"/>

                        <Button Content="Удалить выбранное"
                                Width="150"
                                Click="DeleteWebRuleButton_Click"/>
                    </StackPanel>

                    <DataGrid x:Name="WebRulesDataGrid"
                          Grid.Row="1"
                          AutoGenerateColumns="False"
                          IsReadOnly="False"
                          SelectionMode="Single"
                          CellEditEnding="WebRulesDataGrid_CellEditEnding">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="ID" Binding="{Binding Id}" Width="60" IsReadOnly="True"/>
                            <DataGridTextColumn Header="Приложение" Binding="{Binding Value}" Width="*" IsReadOnly="True"/>
                            <DataGridTextColumn Header="Тип" Binding="{Binding RuleType}" Width="140" IsReadOnly="True"/>
                            <DataGridCheckBoxColumn Header="Активно" Binding="{Binding IsActive}" Width="100"/>
                            <DataGridTextColumn Header="Создано" Binding="{Binding CreatedAt}" Width="180" IsReadOnly="True"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </TabItem>

        </TabControl>
    </Grid>
</Window>